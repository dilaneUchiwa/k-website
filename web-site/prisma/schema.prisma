// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  roleId    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role      UserRole?    @relation(fields: [roleId], references: [id])
  invoices  Invoice[]    @relation("IssuedBy")
  transactions Transaction[] @relation("CreatedBy")
}

model UserRole {
  id          String           @id @default(cuid())
  name        String           @unique
  users       User[]
  permissions RolePermission[]
}

model RolePermission {
  id        String   @id @default(cuid())
  roleId    String
  module    String
  canRead   Boolean  @default(false)
  canWrite  Boolean  @default(false)
  canDelete Boolean  @default(false)

  role      UserRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  brand           String
  model           String
  description     String
  descriptionEn   String?
  descriptionEs   String?
  descriptionZh   String?
  categoryId      String
  featured        Boolean        @default(false)
  status          String         @default("ACTIVE")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  category        Category       @relation(fields: [categoryId], references: [id])
  specs           ProductSpec[]
  images          ProductImage[]
  quotes          QuoteRequest[]
  invoiceItems    InvoiceItem[]
}

model ProductSpec {
  id        String  @id @default(cuid())
  productId String
  key       String
  value     String
  order     Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  publicId  String?
  alt       String?
  order     Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model QuoteRequest {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  country     String?
  productId   String?
  productName String
  quantity    Int      @default(1)
  message     String?
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product? @relation(fields: [productId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}

model InvoiceTemplate {
  id        String    @id @default(cuid())
  name      String
  config    String    @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  invoices  Invoice[]
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  templateId  String?
  issuedById  String?
  clientName  String
  clientEmail String?
  clientPhone String?
  clientAddr  String?
  currency    String        @default("XAF")
  taxRate     Float         @default(0)
  discount    Float         @default(0)
  notes       String?
  status      String        @default("DRAFT")
  issuedAt    DateTime      @default(now())
  dueAt       DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  template    InvoiceTemplate? @relation(fields: [templateId], references: [id])
  issuedBy    User?         @relation("IssuedBy", fields: [issuedById], references: [id])
  items       InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  unit        String?

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  category    String
  amount      Float
  currency    String   @default("XAF")
  description String
  date        DateTime
  reference   String?
  createdById String?
  creditId    String?
  createdAt   DateTime @default(now())

  createdBy   User?   @relation("CreatedBy", fields: [createdById], references: [id])
  credit      Credit? @relation(fields: [creditId], references: [id])
}

model Credit {
  id           String        @id @default(cuid())
  clientName   String
  clientPhone  String?
  amount       Float
  currency     String        @default("XAF")
  description  String?
  status       String        @default("PENDING")
  dueDate      DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Goal {
  id           String   @id @default(cuid())
  title        String
  targetAmount Float
  currency     String   @default("XAF")
  startDate    DateTime
  endDate      DateTime
  type         String   @default("REVENUE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(cuid())
  pageKey   String
  locale    String
  title     String
  body      String
  updatedAt DateTime @updatedAt

  @@unique([pageKey, locale])
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
